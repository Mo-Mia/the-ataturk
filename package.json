{
  "name": "the-ataturk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "db:reset": "pnpm --filter @the-ataturk/data reset",
    "dev": "pnpm --parallel --filter @the-ataturk/server --filter @the-ataturk/web dev",
    "docs:archive-session-status": "tsx scripts/archiveSessionStatus.ts",
    "uat:research": "tsx scripts/uatResearch.ts",
    "test": "pnpm --filter @the-ataturk/engine test && pnpm --filter @the-ataturk/match-engine test && pnpm --filter @the-ataturk/tactics test && pnpm --filter @the-ataturk/data test && pnpm --filter @the-ataturk/server test && pnpm --filter @the-ataturk/web test",
    "lint": "eslint . --max-warnings=0 && prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "24.10.1",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vite": "8.0.10"
  }
}
