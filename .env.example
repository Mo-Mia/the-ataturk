# Google Gemini API key for future commentary generation.
GEMINI_API_KEY=

# ElevenLabs API key for future premium text-to-speech testing.
ELEVENLABS_API_KEY=

# HTTP server port for local development.
PORT=3001

# Future SQLite or hosted database connection string.
DATABASE_URL=

# Server logging verbosity, for example info, debug, warn, or error.
LOG_LEVEL=info

# Node runtime mode, usually development or production.
NODE_ENV=development
