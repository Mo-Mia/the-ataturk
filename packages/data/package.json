{
  "name": "@the-ataturk/data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./llm/gemini": {
      "types": "./src/llm/gemini.ts",
      "default": "./src/llm/gemini.ts"
    },
    "./llm/attribute-validation": {
      "types": "./src/llm/attribute-validation.ts",
      "default": "./src/llm/attribute-validation.ts"
    }
  },
  "scripts": {
    "fc25:chance-creation-investigation": "tsx src/fc25/chanceCreationIsolatedInvestigationCli.ts",
    "fc25:fc26-baseline": "tsx src/fc25/fc26CalibrationBaselineCli.ts",
    "fc25:fc26-multi-matchup": "tsx src/fc25/fc26MultiMatchupCalibrationCli.ts",
    "fc25:import": "tsx src/fc25/importer.ts",
    "fc25:manual-xi-investigation": "tsx src/fc25/manualXiImpactInvestigationCli.ts",
    "fc25:phase13-event-volume": "tsx src/fc25/phase13EventVolumeDiagnosticsCli.ts",
    "fc25:phase8-baseline": "tsx src/fc25/phase8BaselineVerifier.ts",
    "fc25:responsiveness": "tsx src/fc25/realSquadResponsivenessCli.ts",
    "migrate": "tsx src/migrate.ts",
    "reset": "tsx src/reset.ts",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@the-ataturk/match-engine": "workspace:*",
    "better-sqlite3": "12.9.0",
    "csv-parse": "^6.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "tsx": "4.21.0",
    "vitest": "4.0.13"
  }
}
